# Environment Configuration for Livestock and Heat Project
# =========================================================
# Copy this file to .env and update paths for your local setup
# The .env file is gitignored to keep your personal paths private

# Project Root (optional - defaults to location of config.py)
# PROJECT_ROOT=/path/to/your/livestock_and_heat/research

# Data Directories
# ----------------
# Raw MERRA-2 data (hourly temperature and VPD)
# DAILY_DATA_DIR=/path/to/your/daily_data

# Raw MERRA-2 soil and precipitation data
# DAILY_DATA_SOIL_PRECIP_DIR=/path/to/your/daily_data_soil_precip

# Processed Statistics
# --------------------
# Daily nighttime recovery statistics
# PROCESSED_NIGHTTIME_DIR=/path/to/your/processed_nighttime_recovery

# Daily daytime heat statistics
# PROCESSED_DAYTIME_DIR=/path/to/your/processed_daytime_heat

# Daily VPD statistics
# PROCESSED_VPD_DIR=/path/to/your/processed_vpd

# Weekly aggregated data (aligned with cattle slaughter weeks)
# PROCESSED_WEEKLY_DIR=/path/to/your/processed_weekly

# Reference Data
# --------------
# Spatial masks and region definitions
# MASKS_DIR=/path/to/your/masks

# USDA cattle slaughter data
# CATTLE_DATA_DIR=/path/to/your/cattle_data

# Output Directories
# ------------------
# Generated figures and plots
# FIGURES_DIR=/path/to/your/figures

# Generated images
# IMAGES_DIR=/path/to/your/images

# Notes:
# ------
# 1. All paths are optional - if not specified, defaults to relative paths from project root
# 2. Use absolute paths for clarity, especially if data is stored outside project directory
# 3. Uncomment (remove #) and set any paths you want to override
# 4. Paths with spaces should NOT be quoted in .env files
# 5. Example for Google Drive on macOS:
#    PROJECT_ROOT=/Users/username/Library/CloudStorage/GoogleDrive-email/My Drive/project/research
